{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Grip: Current File (Python)",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "cwd": "${fileDirname}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}${pathSeparator}grip-py${pathSeparator}src"
            }
        },
        {
            "name": "Grip: Pytest Current File",
            "type": "python",
            "request": "launch",
            "module": "pytest",
            "args": [
                "-q",
                "${file}"
            ],
            "cwd": "${workspaceFolder}/grip-py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}${pathSeparator}grip-py${pathSeparator}src"
            }
